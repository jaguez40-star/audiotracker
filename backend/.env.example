# Copiar a .env y completar.

# --- OBLIGATORIO ---
# Token de HuggingFace (https://huggingface.co/settings/tokens, tipo "read").
# Ademas hay que aceptar las condiciones de estos TRES modelos con la misma
# cuenta (los tres son de aprobacion automatica):
#   https://huggingface.co/pyannote/segmentation-3.0
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/speaker-diarization-community-1
# El tercero no es obvio: pyannote 4.x saca de ahi el componente PLDA aunque se
# use el modelo 3.1. Sin el, la carga del pipeline falla con 403.
HF_TOKEN=

# Modelo de diarizacion. speaker-diarization-3.1 es el default y el mas probado.
# pyannote 4 trae ademas speaker-community-1, mas nuevo; si se cambia hay que
# aceptar su licencia aparte en HuggingFace.
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1

# --- Motor de transcripcion ---
# whispercpp     -> GPU via Vulkan (recomendado en este equipo)
# faster-whisper -> CPU
# Si se pide whispercpp y falta el binario o el modelo, degrada solo a CPU.
TRANSCRIPTION_ENGINE=whispercpp

# --- whisper.cpp (GPU) ---
# Binario Vulkan precompilado de lemonade-sdk. Rutas relativas a la raiz del
# proyecto; ajustar solo si se movieron de sitio.
# WHISPERCPP_BINARY=C:\APLICACIONES\audio_track\vendor\whisper-vulkan\whisper-cli.exe
# WHISPERCPP_MODEL=C:\APLICACIONES\audio_track\models\ggml-large-v3-q5_0.bin
# false fuerza CPU con el mismo binario y modelo: util para comparar.
WHISPERCPP_USE_GPU=true
WHISPERCPP_THREADS=6

# --- faster-whisper (respaldo en CPU) ---
# tiny | base | small | medium | large-v3
# small es el balance sensato en CPU con 8 GB de RAM.
WHISPER_MODEL=small
WHISPER_COMPUTE_TYPE=int8

# Codigo ISO del idioma, o vacio para deteccion automatica. Aplica a los dos
# motores; fijarlo es mas rapido y preciso que detectar.
WHISPER_LANGUAGE=es

# --- Diarizacion ---
# Dejar vacio para que pyannote deduzca cuantos hablantes hay.
# Fijarlos mejora bastante el resultado si el numero se conoce de antemano.
MIN_SPEAKERS=
MAX_SPEAKERS=

# --- Varios ---
MAX_UPLOAD_MB=500
# true = conservar el audio original tras procesarlo
KEEP_UPLOADS=false
